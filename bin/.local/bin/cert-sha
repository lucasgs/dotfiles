#!/bin/bash

# Usage: ./cert-sha domain.com 
WEBSITE=$1

if [ -z "$WEBSITE" ]; then
    echo "Please provide a domain."
    exit 1
fi

# openssl s_client -connect WEBSITE:443 -servername WEBSITE:443 2>/dev/null \
# | openssl x509 -pubkey -noout \
# | openssl pkey -pubin -outform der \
# | openssl dgst -sha256 -binary \
# | openssl enc -base64

openssl s_client -connect WEBSITE:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | base64
